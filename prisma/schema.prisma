generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  BUSINESS
  INDIVIDUAL_PROVIDER
  CLIENT
}

enum UserRole {
  ADMIN
  DISPATCHER
  RESOURCE
  CLIENT
}

enum AccountUserStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REMOVED
}

enum ResourceStatus {
  AVAILABLE
  BUSY
  OFFLINE
  ON_LEAVE
  DEACTIVATED
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum EngagementStatus {
  UNSCHEDULED
  SCHEDULED
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  REQUESTED
  CONFIRMED
  DECLINED
  CANCELLED
  CONVERTED
}

model Account {
  id        String      @id @default(uuid())
  type      AccountType
  name      String
  slug      String?     @unique
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  users     AccountUser[]
  resources Resource[]
  skills    Skill[]
  engagements Engagement[]
  providerReviews ProviderReview[]
  bookingRequests BookingRequest[]
}

model UserProfile {
  id            String   @id
  email         String   @unique
  fullName      String
  avatarUrl     String?
  phone         String?
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts      AccountUser[]
  resources     Resource[]
}

model AccountUser {
  id          String            @id @default(uuid())
  accountId   String
  userId      String
  role        UserRole
  status      AccountUserStatus @default(ACTIVE)
  invitedById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  account     Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user        UserProfile       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([accountId, userId])
  @@index([userId])
  @@index([accountId, role])
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  description String?
  roles       RolePermission[]
}

model RolePermission {
  id           String     @id @default(uuid())
  role         UserRole
  permissionId String

  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
}

model Skill {
  id        String   @id @default(uuid())
  accountId String
  name      String
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account   Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  resources ResourceSkill[]

  @@unique([accountId, name])
  @@index([accountId])
}

model Resource {
  id             String         @id @default(uuid())
  accountId      String
  userProfileId  String?
  photoUrl       String?
  name           String
  email          String?
  phone          String?
  title          String?
  status         ResourceStatus @default(AVAILABLE)
  isActive       Boolean        @default(true)
  locationLabel  String?
  latitude       Decimal?       @db.Decimal(10, 7)
  longitude      Decimal?       @db.Decimal(10, 7)
  lastSeenAt     DateTime?
  notes          String?
  publicSlug     String?
  publicBio      String?
  publicHeadline String?
  serviceArea    String?
  yearsExperience Int?
  responseTimeMinutes Int?
  ratingAverage  Decimal?       @db.Decimal(3, 2)
  ratingCount    Int            @default(0)
  deactivatedAt DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  account        Account                @relation(fields: [accountId], references: [id], onDelete: Cascade)
  userProfile    UserProfile?           @relation(fields: [userProfileId], references: [id], onDelete: SetNull)
  skills         ResourceSkill[]
  availability   ResourceAvailability[]
  statusEvents   ResourceStatusEvent[]
  engagements    Engagement[]
  publicServices ProviderService[]
  reviews        ProviderReview[]
  bookingRequests BookingRequest[]

  @@index([accountId, status])
  @@index([accountId, isActive])
  @@index([userProfileId])
  @@unique([accountId, publicSlug])
}

model Engagement {
  id              String           @id @default(uuid())
  accountId       String
  resourceId      String?
  title           String
  clientName      String
  clientEmail     String?
  clientPhone     String?
  serviceType     String?
  description     String?
  status          EngagementStatus @default(UNSCHEDULED)
  scheduledStart  DateTime?
  scheduledEnd    DateTime?
  locationLabel   String?
  latitude        Decimal?         @db.Decimal(10, 7)
  longitude       Decimal?         @db.Decimal(10, 7)
  cancellationReason String?
  cancelledAt     DateTime?
  completedAt     DateTime?
  createdBy       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  account         Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  resource        Resource?        @relation(fields: [resourceId], references: [id], onDelete: SetNull)
  statusEvents    EngagementStatusEvent[]

  @@index([accountId, status])
  @@index([accountId, scheduledStart])
  @@index([resourceId, scheduledStart, scheduledEnd])
}

model EngagementStatusEvent {
  id           String           @id @default(uuid())
  engagementId String
  status       EngagementStatus
  note         String?
  createdBy    String?
  createdAt    DateTime         @default(now())

  engagement   Engagement       @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@index([engagementId, createdAt])
}

model ResourceSkill {
  resourceId String
  skillId    String
  createdAt  DateTime @default(now())

  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  skill      Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([resourceId, skillId])
  @@index([skillId])
}

model ResourceAvailability {
  id         String   @id @default(uuid())
  resourceId String
  weekday    Weekday
  startTime  String
  endTime    String
  timezone   String   @default("UTC")
  isWorking  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([resourceId, weekday])
  @@index([resourceId])
}

model ResourceStatusEvent {
  id         String         @id @default(uuid())
  resourceId String
  status     ResourceStatus
  note       String?
  createdBy  String?
  createdAt  DateTime       @default(now())

  resource   Resource       @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId, createdAt])
}

model ProviderService {
  id          String   @id @default(uuid())
  resourceId  String
  name        String
  description String?
  priceLabel  String?
  durationMinutes Int?
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  resource    Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  bookingRequests BookingRequest[]

  @@index([resourceId])
}

model ProviderReview {
  id          String   @id @default(uuid())
  accountId   String
  resourceId  String
  reviewerName String
  rating      Int
  comment     String
  serviceName String?
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())

  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  resource    Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([resourceId, isPublished])
}

model BookingRequest {
  id             String        @id @default(uuid())
  accountId      String
  resourceId     String
  providerServiceId String?
  status         BookingStatus @default(REQUESTED)
  clientName     String
  clientEmail    String
  clientPhone    String?
  serviceName    String
  requestedStart DateTime
  requestedEnd   DateTime?
  locationLabel  String?
  notes          String?
  source         String        @default("public_profile")
  engagementId   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  account        Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  resource       Resource      @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  providerService ProviderService? @relation(fields: [providerServiceId], references: [id], onDelete: SetNull)

  @@index([accountId, status])
  @@index([resourceId, requestedStart])
  @@index([clientEmail])
}

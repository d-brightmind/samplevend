generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  BUSINESS
  INDIVIDUAL_PROVIDER
  CLIENT
}

enum UserRole {
  ADMIN
  DISPATCHER
  RESOURCE
  CLIENT
}

enum AccountUserStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REMOVED
}

enum ResourceStatus {
  AVAILABLE
  BUSY
  OFFLINE
  ON_LEAVE
  DEACTIVATED
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model Account {
  id        String      @id @default(uuid())
  type      AccountType
  name      String
  slug      String?     @unique
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  users     AccountUser[]
  resources Resource[]
  skills    Skill[]
}

model UserProfile {
  id            String   @id
  email         String   @unique
  fullName      String
  avatarUrl     String?
  phone         String?
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts      AccountUser[]
  resources     Resource[]
}

model AccountUser {
  id          String            @id @default(uuid())
  accountId   String
  userId      String
  role        UserRole
  status      AccountUserStatus @default(ACTIVE)
  invitedById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  account     Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user        UserProfile       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([accountId, userId])
  @@index([userId])
  @@index([accountId, role])
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  description String?
  roles       RolePermission[]
}

model RolePermission {
  id           String     @id @default(uuid())
  role         UserRole
  permissionId String

  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
}

model Skill {
  id        String   @id @default(uuid())
  accountId String
  name      String
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account   Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  resources ResourceSkill[]

  @@unique([accountId, name])
  @@index([accountId])
}

model Resource {
  id             String         @id @default(uuid())
  accountId      String
  userProfileId  String?
  photoUrl       String?
  name           String
  email          String?
  phone          String?
  title          String?
  status         ResourceStatus @default(AVAILABLE)
  isActive       Boolean        @default(true)
  locationLabel  String?
  latitude       Decimal?       @db.Decimal(10, 7)
  longitude      Decimal?       @db.Decimal(10, 7)
  lastSeenAt     DateTime?
  notes          String?
  deactivatedAt DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  account        Account                @relation(fields: [accountId], references: [id], onDelete: Cascade)
  userProfile    UserProfile?           @relation(fields: [userProfileId], references: [id], onDelete: SetNull)
  skills         ResourceSkill[]
  availability   ResourceAvailability[]
  statusEvents   ResourceStatusEvent[]

  @@index([accountId, status])
  @@index([accountId, isActive])
  @@index([userProfileId])
}

model ResourceSkill {
  resourceId String
  skillId    String
  createdAt  DateTime @default(now())

  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  skill      Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([resourceId, skillId])
  @@index([skillId])
}

model ResourceAvailability {
  id         String   @id @default(uuid())
  resourceId String
  weekday    Weekday
  startTime  String
  endTime    String
  timezone   String   @default("UTC")
  isWorking  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([resourceId, weekday])
  @@index([resourceId])
}

model ResourceStatusEvent {
  id         String         @id @default(uuid())
  resourceId String
  status     ResourceStatus
  note       String?
  createdBy  String?
  createdAt  DateTime       @default(now())

  resource   Resource       @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId, createdAt])
}
